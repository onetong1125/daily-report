{
  "name": "daily-report",
  "version": "0.2.3",
  "description": "自动日报工具：聚合 Git、GitHub、Claude Code、Codex CLI 的每日活动，生成日报和明日行动建议",
  "main": "dist/index.js",
  "bin": {
    "daily-report": "./bin/daily-report"
  },
  "scripts": {
    "build": "tsc",
    "release": "npm run build && npm pack && npm install -g daily-report-*.tgz && rm daily-report-*.tgz",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "daily-report",
    "cli",
    "productivity"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "inquirer": "^9.3.7"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
